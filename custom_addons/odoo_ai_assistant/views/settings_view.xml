<odoo>
    <record id="res_config_settings_view_form_ai_chat" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ai.chat</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="assistant_ai" string="Asistente de IA" groups="base.group_system">
                    <block title="Memoria a corto plazo">
                        <setting>
                            <field name="ai_chat_history_limit"/>
                            <div class="text-muted">
                                Cantidad de mensajes recientes a enviar como memoria.
                            </div>
                        </setting>
                        <setting>
                            <field name="ai_chat_use_server_history"/>
                            <div class="text-muted">
                                Usar historial guardado en servidor (ai.chat) como memoria.
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
